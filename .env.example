# --- Data Source Credentials ---
# Korean Official Data Sources (DART / KRX)
DART_API_KEY=your_dart_api_key_here
KRX_API_KEY=your_krx_api_key_here

# Global Financial & Economic Data Sources (FRED / Alpha Vantage / Financial Modeling Prep)
FRED_API_KEY=your_fred_api_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here
FMP_API_KEY=your_fmp_api_key_here

# Korean Macro & Trade Statistical Sources (KOSIS / Customs Trade API)
KOSIS_API_KEY=your_kosis_api_key_here
CUSTOMS_TRADE_API_KEY=your_customs_trade_api_key_here
CUSTOMS_TRADE_FORMAT=XML
CUSTOMS_TRADE_ENDPOINT=https://apis.data.go.kr/1220000/nitemtrade
